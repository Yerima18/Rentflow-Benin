generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Landlord {
  id         String     @id @default(cuid())
  email      String     @unique
  password   String // Hashed password
  name       String
  properties Property[]
}

model Property {
  id         String    @id @default(cuid())
  name       String
  address    String
  units      Int
  landlordId String
  landlord   Landlord  @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  tenants    Tenant[]
  expenses   Expense[]
}

model Tenant {
  id         String    @id @default(cuid())
  fullName   String
  phone      String
  unitNumber String
  rentAmount Float
  dueDate    Int // Day of the month (e.g., 1-31)
  leaseStart DateTime? // Optional lease start date
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payments   Payment[]
}

model Payment {
  id       String   @id @default(cuid())
  amount   Float
  date     DateTime @default(now())
  status   String // 'PAID', 'PENDING', 'OVERDUE'
  month    String // e.g., "2023-10"
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  description String
  category    String // e.g., "Maintenance", "Taxes", "Utilities", "Other"
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}
